---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
    const blog = await getCollection('blog')
    return blog.map(post => ({
        params: { slug: post.id },
        props: { post }
    }))
}

const { post } = Astro.props
const { Content } = await render(post)
const { titulo, autor, fecha, descripcion, tecnologias, hashtags, estado } = post.data

const parseHashtags = (str: string) =>
    str.split(/\s+/).filter(t => t.startsWith('#')).map(t => t.slice(1))

const tags = parseHashtags(hashtags)

const tiempoLectura = (desc: string) =>
    Math.max(1, Math.ceil(desc.split(/\s+/).length / 200))
---

<Layout title={`${titulo} · blog · obviousfancy`}>
  <div class="page">

    <!-- Navegación de vuelta -->
    <a
      href="/blog"
      style="display: inline-flex; align-items: center; gap: 6px; color: var(--fg-3); font-size: 12px; text-decoration: none; margin-bottom: 28px; transition: color 0.15s;"
      onmouseover="this.style.color='var(--fg-0)'"
      onmouseout="this.style.color='var(--fg-3)'"
    >
      ← blog/
    </a>

    <!-- Encabezado del post -->
    <div style="margin-bottom: 40px; max-width: 72ch;">
      <h1 style="font-size: 30px; font-weight: 700; color: var(--fg-0); margin: 0 0 16px; font-family: var(--font-mono); line-height: 1.3;">
        {titulo}
      </h1>

      <!-- Meta: autor · fecha · tiempo -->
      <div style="display: flex; align-items: center; gap: 10px; color: var(--fg-3); font-size: 11.5px; font-family: var(--font-mono); margin-bottom: 16px; flex-wrap: wrap;">
        <span>{autor}</span>
        <span style="color: var(--border);">·</span>
        <span>{fecha.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span style="color: var(--border);">·</span>
        <span>{tiempoLectura(descripcion)} min de lectura</span>
      </div>

      <!-- Descripción -->
      <p style="color: var(--fg-2); font-family: var(--font-sans); font-size: 14px; line-height: 1.7; margin: 0 0 20px;">
        {descripcion}
      </p>

      <!-- Tags -->
      <div style="display: flex; flex-wrap: wrap; gap: 5px;">
        {tags.map(tag => (
          <span class="tag"># {tag}</span>
        ))}
      </div>
    </div>

    <!-- Separador -->
    <hr style="margin-bottom: 40px;" />

    <!-- Contenido Markdown -->
    <div class="prose">
      <Content />
    </div>

    <!-- Footer del post -->
    <div style="margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--border-soft); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
      <a
        href="/blog"
        style="color: var(--fg-3); font-size: 12px; font-family: var(--font-mono); text-decoration: none; transition: color 0.15s;"
        onmouseover="this.style.color='var(--fg-0)'"
        onmouseout="this.style.color='var(--fg-3)'"
      >
        ← más posts
      </a>
      <div style="display: flex; gap: 6px; flex-wrap: wrap;">
        {tags.map(tag => (
          <span class="tag"># {tag}</span>
        ))}
      </div>
    </div>

  </div>
</Layout>
