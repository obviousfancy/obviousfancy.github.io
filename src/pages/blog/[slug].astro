---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths(){
    const blog = await getCollection('blog')
    return blog.map(post => ({
        params: { slug: post.id },
        props: { post }
    }))
}

const { post } = Astro.props
const { Content } = await render(post)
const { titulo, descripcion, tecnologias, hashtags, github, estado, fecha } = post.data

const parseHashtags = (str: string) =>
    str.split(/\s+/).filter(t => t.startsWith('#')).map(t => t.slice(1))
const hashtags_parsed = parseHashtags(hashtags)
---

<Layout title={`${titulo} · obviousfancy`}>
  <div class="page" style="max-width: 860px;">

    <a href="/blog" style="color: var(--fg-3); font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 24px;">
      ← blog/
    </a>

    <div style="margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--border-soft);">
      <div style="color: var(--fg-3); font-size: 11px; font-family: var(--font-mono); margin-bottom: 12px;">
        {fecha.toISOString().slice(0, 10)}
      </div>

      <h1 style="font-size: 1.9rem; font-weight: 700; color: var(--fg-0); font-family: var(--font-mono); margin: 0 0 12px; line-height: 1.25;">
        {titulo}
      </h1>

      <p style="color: var(--fg-2); font-family: var(--font-sans); font-size: 15px; line-height: 1.6; margin: 0 0 18px;">
        {descripcion}
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 6px; align-items: center;">
        <span class={`tag ${estado === 'Completado' ? 'accent-2' : estado === 'En desarrollo' ? 'accent' : ''}`}>
          {estado}
        </span>
        {hashtags_parsed.map(tag => (
          <span class="tag"># {tag}</span>
        ))}
      </div>
    </div>

    <div class="prose">
      <Content />
    </div>

    {github && (
      <div style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border-soft);">
        <a
          href={github}
          class="card-glass"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 8px 20px; border-radius: 4px; color: var(--fg-0); font-size: 12px; font-family: var(--font-mono);"
        >
          Ver en GitHub →
        </a>
      </div>
    )}

  </div>
</Layout>
