---
import Layout from '../layouts/Layout.astro'
import ProjectCard from '../components/react/ProjectCard.tsx'
import { getCollection } from 'astro:content'

const proyectos = await getCollection('proyectos')
const proyectosOrdenados = proyectos.sort((a, b) => a.data.orden - b.data.orden)

const estadoToStatus = (estado: string): 'ship' | 'beta' | 'alpha' | 'wip' => {
    if (estado === 'Completado') return 'ship'
    if (estado === 'En desarrollo') return 'wip'
    if (estado === 'Pausado') return 'alpha'
    return 'wip'
}
---

<Layout title="proyectos/ · obviousfancy">
  <div class="page">

    <div class="page-head">
      <div>
        <h1 class="page-title">
          <span class="pre">//</span>
          proyectos
          <span class="num">{proyectosOrdenados.length}</span>
        </h1>
        <div class="page-sub">
          Hardware · Firmware · Software companion
        </div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; align-items: start;">
      {proyectosOrdenados.map(proyecto => (
        <ProjectCard
          client:visible
          id={proyecto.id}
          title={proyecto.data.titulo}
          year="2026"
          tag={proyecto.data.tecnologias.slice(0, 3).join(' · ')}
          summary={proyecto.data.descripcion}
          stack={proyecto.data.tecnologias}
          status={estadoToStatus(proyecto.data.estado)}
          role="solo"
          color="accent"
          metrics={[
            { k: 'estado', v: proyecto.data.estado },
            { k: 'stack', v: String(proyecto.data.tecnologias.length) + ' techs' },
            { k: 'orden', v: String(proyecto.data.orden) },
          ]}
          url={`/proyectos/${proyecto.id}`}
        />
      ))}
    </div>

    <div style="display: flex; gap: 12px; margin-top: 48px; padding-bottom: 32px;">
      <a
        href="https://github.com/obviousfancy"
        class="card-glass"
        style="padding: 8px 24px; border-radius: 4px; color: var(--fg-0); font-size: 12px;"
      >
        GitHub →
      </a>
      <a
        href="/"
        style="padding: 8px 24px; border-radius: 4px; background: var(--accent); color: var(--bg-0); font-size: 12px;"
      >
        ← Inicio
      </a>
    </div>

  </div>
</Layout>
