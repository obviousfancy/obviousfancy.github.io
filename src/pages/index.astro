---
import Layout from '../layouts/Layout.astro'
import Terminal from '../components/react/Terminal.tsx'
---

<Layout title="obviousfancy · home.tsx">
  <div class="page">
    <Terminal client:load />

    <!-- Cards rápidas debajo de la terminal, estilo "atajos" -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 32px;">
      <a href="/proyectos" class="card card-glass fade-in" style="padding: 18px; text-decoration: none; display: block;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <strong style="color: var(--fg-0); font-family: var(--font-mono);">Proyectos</strong>
          <span style="color: var(--accent);">→</span>
        </div>
        <div style="color: var(--fg-3); font-size: 11.5px; margin-top: 6px;">
          4 casos de estudio
        </div>
      </a>

      <a href="/blog" class="card card-glass fade-in" style="padding: 18px; text-decoration: none; display: block;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <strong style="color: var(--fg-0); font-family: var(--font-mono);">Blog</strong>
          <span style="color: var(--accent);">→</span>
        </div>
        <div style="color: var(--fg-3); font-size: 11.5px; margin-top: 6px;">
          12 artículos técnicos
        </div>
      </a>

      <a href="/wiki" class="card card-glass fade-in" style="padding: 18px; text-decoration: none; display: block;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <strong style="color: var(--fg-0); font-family: var(--font-mono);">Wiki</strong>
          <span style="color: var(--accent);">→</span>
        </div>
        <div style="color: var(--fg-3); font-size: 11.5px; margin-top: 6px;">
          notas técnicas
        </div>
      </a>

      <a href="/contacto" class="card card-glass fade-in" style="padding: 18px; text-decoration: none; display: block;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <strong style="color: var(--fg-0); font-family: var(--font-mono);">Contacto</strong>
          <span style="color: var(--accent);">→</span>
        </div>
        <div style="color: var(--fg-3); font-size: 11.5px; margin-top: 6px;">
          colaboraciones
        </div>
      </a>
    </div>
  </div>
</Layout>
